# Andro-CD configuration — copy to .env and fill in; docker compose picks it up automatically.
# .env is gitignored, never commit real secrets.
#
# Minimal secure setup checklist:
#   1. AUTH_MODE=github + a GitHub OAuth app (callback: $PUBLIC_URL/api/auth/callback)
#   2. SESSION_SECRET + ENCRYPTION_KEY set to long random values (openssl rand -hex 32)
#   3. POSTGRES_PASSWORD changed from the default
#   4. RBAC_ADMINS set + RBAC_DEFAULT_ROLE=viewer

# ============================= Authentication =============================
# none   = no login, everyone is admin (ONLY for private/local use)
# github = GitHub OAuth login required for the UI and API
# oidc   = generic OpenID Connect (Google, Okta, Keycloak, Dex, Auth0, Azure AD)
AUTH_MODE=github

# --- github ---
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Who may log in — set one of these (or both):
GITHUB_ALLOWED_USERS=your-github-username
#GITHUB_ALLOWED_ORG=your-org

# --- oidc (only when AUTH_MODE=oidc) ---
# Discovery-based: point at the issuer; /.well-known/openid-configuration is fetched.
# Register the redirect URI $PUBLIC_URL/api/auth/oidc/callback with your provider.
#OIDC_ISSUER=https://accounts.google.com
#OIDC_CLIENT_ID=xxxxxxxx
#OIDC_CLIENT_SECRET=xxxxxxxx
#OIDC_SCOPES=openid email profile          # add "groups" for group-based allowlists
# Which claim becomes the username used for RBAC (email | preferred_username | sub):
#OIDC_USERNAME_CLAIM=email
# Who may log in — set at least one (each configured allowlist must pass):
#OIDC_ALLOWED_USERS=alice@example.com,bob@example.com
#OIDC_ALLOWED_DOMAINS=example.com
#OIDC_ALLOWED_GROUPS=platform,sre
#OIDC_GROUPS_CLAIM=groups

# Signs session cookies; MUST be stable across restarts or everyone is logged out.
# Generate: openssl rand -hex 32
SESSION_SECRET=change-me-long-random-string
# Encrypts stored AWS profile credentials (falls back to SESSION_SECRET if unset).
# Set it separately so rotating the session secret doesn't lose stored profiles.
#ENCRYPTION_KEY=change-me-other-long-random-string

# External URL of this deployment — used for the OAuth callback, CSRF checks
# and cookie security (https:// enables Secure cookies + HSTS).
PUBLIC_URL=http://localhost:8080

# ================================= RBAC ===================================
# Roles: admin (everything) > operator (sync/rollback/prune/refresh) > viewer (read-only).
# Without any RBAC vars every logged-in user is admin (backwards compatible).
# Values are matched against the login: GitHub username, or the OIDC username claim
# (e.g. alice@example.com when OIDC_USERNAME_CLAIM=email).
#RBAC_ADMINS=your-github-username
#RBAC_OPERATORS=teammate1,teammate2
#RBAC_DEFAULT_ROLE=viewer

# Static API tokens for CI/automation, sent as "Authorization: Bearer <token>".
# Format: token:role[,token2:role2]. Generate tokens with: openssl rand -hex 32
#API_TOKENS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx:operator

# ======================== Git repositories (GitOps) =======================
# Optional bootstrap repo — repos are normally added at runtime via the UI
# ("Repositories") or POST /api/repos and persisted in the database.
#GIT_REPO_URL=https://github.com/you/ecs-manifests
#GIT_BRANCH=main
#GIT_PATH=
#GIT_TOKEN=

# Seconds between reconcile loops (webhook pushes trigger instant sync too).
#SYNC_INTERVAL=60
# Apply changes automatically (true) or only surface OutOfSync for manual sync (false).
#AUTO_SYNC=true
# Dry-run: record what WOULD change but never call AWS mutation APIs
# (great for demos, IAM permission testing and observation-only setups).
#DRY_RUN=false
# Parallel diff workers per reconcile pass (raise for very large fleets).
#RECONCILE_WORKERS=8
# Deregister old ACTIVE task definition revisions beyond the newest N after each
# sync (0 = keep all). The revision in use is never removed.
#KEEP_TASKDEF_REVISIONS=0

# GitHub push webhook (POST /api/webhook/github) — set the same secret in the
# GitHub webhook config. HMAC-verified; enables instant syncs on push.
#WEBHOOK_SECRET=

# ================================= AWS ====================================
# Default region (manifests and named profiles can override per app).
AWS_REGION=eu-central-1
# Credentials come from the default boto3 chain: IAM role (in ECS/EC2), env
# vars below, or the mounted ~/.aws. Extra accounts: "AWS Profiles" in the UI.
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_SESSION_TOKEN=
#AWS_PROFILE=

# ============================ Observability ===============================
# Slack (or compatible) incoming webhook: sync succeeded/failed, app degraded.
#SLACK_WEBHOOK_URL=
# Protect GET /metrics with a bearer token (unset = publicly readable).
#METRICS_TOKEN=
# Log output format: text (default) or json (for CloudWatch/Loki ingestion).
#LOG_FORMAT=text

# ============================== Database ==================================
# Postgres password used by docker-compose (change it!).
POSTGRES_PASSWORD=change-me-db-password
# Outside compose you can point at any SQLAlchemy URL; unset = sqlite fallback.
#DATABASE_URL=postgresql+psycopg://androcd:pass@db:5432/androcd
